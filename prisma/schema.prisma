generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @unique @db.VarChar(100)
  password   String   @db.VarChar(255)
  created_at DateTime @default(now())

  @@map("admins")
}

model User {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(100)
  email      String     @unique @db.VarChar(100)
  password   String     @db.VarChar(255)
  phone      String?    @db.VarChar(20)
  address    String?    @db.Text
  created_at DateTime   @default(now())
  cart       Cart[]
  wishlist   Wishlist[]
  orders     Order[]

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(100)
  slug     String    @unique @db.VarChar(100)
  products Product[]

  @@map("categories")
}

model Product {
  id             Int              @id @default(autoincrement())
  category_id    Int?
  name           String           @db.VarChar(200)
  slug           String           @unique @db.VarChar(200)
  description    String?          @db.Text
  price          Decimal          @db.Decimal(10, 2)
  discount_price Decimal?         @default(0) @db.Decimal(10, 2)
  stock          Int?             @default(0)
  sku            String?          @unique @db.VarChar(50)
  status         String?          @default("Aktif")
  is_featured    Boolean?         @default(false)
  is_bestseller  Boolean?         @default(false)
  is_popular     Boolean?         @default(false)
  is_new         Boolean?         @default(true)
  created_at     DateTime         @default(now())
  category       Category?        @relation(fields: [category_id], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]
  cart           Cart[]
  wishlist       Wishlist[]
  order_items    OrderItem[]

  @@map("products")
}

model ProductImage {
  id         Int      @id @default(autoincrement())
  product_id Int
  image_path String   @db.VarChar(255)
  is_primary Boolean? @default(false)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id               Int         @id @default(autoincrement())
  product_id       Int
  color            String?     @db.VarChar(50)
  size             String?     @db.VarChar(50)
  additional_price Decimal?    @default(0) @db.Decimal(10, 2)
  stock            Int?        @default(0)
  product          Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)
  cart             Cart[]
  order_items      OrderItem[]

  @@map("product_variants")
}

model Cart {
  id         Int             @id @default(autoincrement())
  user_id    Int?
  session_id String?         @db.VarChar(100)
  product_id Int
  variant_id Int?
  qty        Int?            @default(1)
  created_at DateTime        @default(now())
  user       User?           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@map("cart")
}

model Wishlist {
  id         Int      @id @default(autoincrement())
  user_id    Int
  product_id Int
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("wishlist")
}

model Order {
  id             Int         @id @default(autoincrement())
  order_number   String      @unique @db.VarChar(50)
  user_id        Int?
  name           String      @db.VarChar(100)
  email          String      @db.VarChar(100)
  phone          String      @db.VarChar(20)
  province       String      @db.VarChar(100)
  city           String      @db.VarChar(100)
  district       String      @db.VarChar(100)
  postal_code    String      @db.VarChar(10)
  address        String      @db.Text
  notes          String?     @db.Text
  total_amount   Decimal     @db.Decimal(10, 2)
  shipping_fee   Decimal?    @default(0) @db.Decimal(10, 2)
  discount       Decimal?    @default(0) @db.Decimal(10, 2)
  payment_method String      @db.VarChar(50)
  status         String?     @default("Pending")
  created_at     DateTime    @default(now())
  user           User?       @relation(fields: [user_id], references: [id])
  order_items    OrderItem[]

  @@map("orders")
}

model OrderItem {
  id         Int             @id @default(autoincrement())
  order_id   Int
  product_id Int
  variant_id Int?
  price      Decimal         @db.Decimal(10, 2)
  qty        Int
  order      Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variant_id], references: [id])

  @@map("order_items")
}

model Message {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  email      String   @db.VarChar(100)
  subject    String?  @db.VarChar(200)
  message    String   @db.Text
  is_read    Boolean? @default(false)
  created_at DateTime @default(now())

  @@map("messages")
}

model Contact {
  id         Int     @id @default(autoincrement())
  whatsapp   String? @db.VarChar(20)
  email      String? @db.VarChar(100)
  instagram  String? @db.VarChar(100)
  facebook   String? @db.VarChar(100)
  tiktok     String? @db.VarChar(100)
  youtube    String? @db.VarChar(100)
  address    String? @db.Text
  maps_embed String? @db.Text
  work_hours String? @db.VarChar(255)

  @@map("contacts")
}

model Setting {
  id            Int     @id @default(autoincrement())
  setting_key   String  @unique @db.VarChar(50)
  setting_value String? @db.Text

  @@map("settings")
}

model Banner {
  id          Int     @id @default(autoincrement())
  image_path  String  @db.VarChar(255)
  title       String? @db.VarChar(100)
  subtitle    String? @db.VarChar(255)
  link        String? @db.VarChar(255)
  order_index Int?    @default(0)

  @@map("banners")
}

model Testimonial {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  content    String   @db.Text
  rating     Int?     @default(5)
  created_at DateTime @default(now())

  @@map("testimonials")
}
